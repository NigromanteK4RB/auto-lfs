#!/bin/sh


SCRIPT_DIR=$(dirname "`realpath ${0}`")

SOURCES_DIR="${SCRIPT_DIR}"/sources
BUILD_SCRIPTS="${SCRIPT_DIR}"/build_scripts
BUILD_DIR="${SCRIPT_DIR}"/build

ARCH=$(uname -m)

source "${SCRIPT_DIR}/custom_vars"

if [ ! -d  "${LFS}" ]
then
    LFS="${SCRIPT_DIR}"/system
fi

if [ ! -d "${LFS}/${TOOLS}" ]
then
    mkdir -pv "${LFS}/${TOOLS}"
    chown -v ${USER} "${LFS}/${TOOLS}"
fi

sudo rm "/${TOOLS}"
sudo ln -sv "${LFS}/${TOOLS}" /

export LFS LC_ALL LFS_TGT PATH MAKEFLAGS SOURCES_DIR BUILD_DIR ARCH BUILD_SCRIPTS CUSTOM_PREFIX TOOLS

for script in "${BUILD_SCRIPTS}/tools"/???-*
do
    sh "${script}"
    result=$?
    case "${result}" in
        1)
            exit "${result}"
        ;;
        2)
            exit "${result}"
        ;;
    esac
done
